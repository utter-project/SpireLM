import "models_spire.tconf"
import "dsu_spire.tconf"

global {

    ducttape_experimental_imports=true
    ducttape_experimental_submitters=true
    ducttape_experimental_multiproc=true

    # The location at which results should be stored
    ducttape_output=/mnt/scratch-artemis/bpop/SpireLM/experiments/asr-spire-outputs

    # Fill with the path to SpireLM
    repo=/mnt/data-artemis/bpop/SpireLM

    seed=42

    # asr_dataset_config and asr_text_field: values for defining which
    asr_dataset_config=(
        ASRDataset:
            ls_clean="/mnt/data-artemis/bpop/SpireLM/dataset-configs/disk/librispeech_asr-clean-test.yml"
            ls_other="/mnt/data-artemis/bpop/SpireLM/dataset-configs/disk/librispeech_asr-other-test.yml"
            fleurs="/mnt/data-artemis/bpop/SpireLM/dataset-configs/fleurs-en_us-test.yml"
            voxpopuli="/mnt/data-artemis/bpop/SpireLM/dataset-configs/disk/voxpopuli-en-test.yml"
    )
    asr_text_field=(
        ASRDataset:
            ls_clean="text"
            ls_other="text"
            fleurs="raw_transcription"
            voxpopuli="normalized_text"
    )

    template=(
        Template:
            spire_style="/mnt/data-artemis/bpop/SpireLM/instruction-templates/spire-style-template.json"
    )

    # Max tokens for decoding
    max_tokens=(MaxTokens: 256 128 512)

    # text normalization for evaluations
    normalizer=(Normalizer: english basic)
}
